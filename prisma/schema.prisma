generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "mongodb"
  url      = env("MONGO_URI")
}

model User {
  id                       String                @id @default(auto()) @map("_id") @db.ObjectId
  name                     String?
  email                    String?               @unique
  emailVerified            DateTime?
  image                    String?
  accounts                 Account[]
  sessions                 Session[]
  ownedPlaygrounds         Playground[]          @relation("PlaygroundOwner")
  playgroundMemberships    PlaygroundMember[]
  playgroundInvitesCreated PlaygroundInvite[]    @relation("PlaygroundInviteCreator")
  playgroundInvitesAccepted PlaygroundInvite[]   @relation("PlaygroundInviteAcceptor")
  playgroundChatMessages   PlaygroundChatMessage[] @relation("PlaygroundChatAuthor")
  playgroundActivities     PlaygroundActivity[]  @relation("PlaygroundActivityActor")
  playgroundEntriesUpdated PlaygroundEntry[]     @relation("PlaygroundEntryUpdatedBy")
  assignedPlaygroundEntries PlaygroundEntry[]    @relation("PlaygroundEntryAssignee")
}

model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.String
  access_token      String? @db.String
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.String
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum WorkspaceMode {
  PERSONAL
  COLLABORATION
}

enum PlaygroundSetupType {
  TEMPLATE
  GITHUB
}

enum WorkspaceRulesMode {
  STRICT
  LENIENT
}

enum WorkspaceMemberRole {
  OWNER
  ADMIN
  MEMBER
}

enum PlaygroundEntryType {
  FILE
  FOLDER
}

enum PlaygroundInviteStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

enum PlaygroundActivityType {
  MEMBER_JOINED
  MEMBER_LEFT
  FILE_OPENED
  FILE_PUSHED
  VOICE_JOINED
  VOICE_LEFT
  FILE_ASSIGNED
  REPOSITORY_SYNCED
  MEMBER_ROLE_CHANGED
  MEMBER_REMOVED
  INVITE_CREATED
  INVITE_ACCEPTED
}

enum PlaygroundTemplate {
  REACT
  NEXTJS
  EXPRESS
  VUE
  HONO
  ANGULAR
  GITHUB
}

model Playground {
  id                 String                  @id @default(auto()) @map("_id") @db.ObjectId
  name               String
  description        String?
  mode               WorkspaceMode
  setupType          PlaygroundSetupType
  rules              WorkspaceRulesMode
  template           PlaygroundTemplate
  workspaceLink      String                  @unique
  repositoryFullName String?
  collaborators      String[]
  starredByIds       String[]
  ownerId            String                  @db.ObjectId
  owner              User                    @relation("PlaygroundOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members            PlaygroundMember[]
  entries            PlaygroundEntry[]
  invites            PlaygroundInvite[]
  chatMessages       PlaygroundChatMessage[]
  activities         PlaygroundActivity[]
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
}

model PlaygroundMember {
  id           String              @id @default(auto()) @map("_id") @db.ObjectId
  playgroundId String              @db.ObjectId
  userId       String              @db.ObjectId
  role         WorkspaceMemberRole
  isVoiceMuted Boolean             @default(false)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  playground   Playground          @relation(fields: [playgroundId], references: [id], onDelete: Cascade)
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([playgroundId, userId])
}

model PlaygroundEntry {
  id             String             @id @default(auto()) @map("_id") @db.ObjectId
  playgroundId   String             @db.ObjectId
  type           PlaygroundEntryType
  path           String
  parentPath     String?
  name           String
  fileExtension  String?
  content        String?
  revision       Int                @default(1)
  assignedUserId String?            @db.ObjectId
  updatedById    String?            @db.ObjectId
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  playground     Playground         @relation(fields: [playgroundId], references: [id], onDelete: Cascade)
  assignedUser   User?              @relation("PlaygroundEntryAssignee", fields: [assignedUserId], references: [id])
  updatedBy      User?              @relation("PlaygroundEntryUpdatedBy", fields: [updatedById], references: [id])

  @@unique([playgroundId, path])
}

model PlaygroundInvite {
  id           String                @id @default(auto()) @map("_id") @db.ObjectId
  playgroundId String                @db.ObjectId
  email        String?
  role         WorkspaceMemberRole   @default(MEMBER)
  tokenHash    String                @unique
  createdById  String                @db.ObjectId
  acceptedById String?               @db.ObjectId
  status       PlaygroundInviteStatus @default(PENDING)
  expiresAt    DateTime
  acceptedAt   DateTime?
  lastSentAt   DateTime?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  playground   Playground            @relation(fields: [playgroundId], references: [id], onDelete: Cascade)
  createdBy    User                  @relation("PlaygroundInviteCreator", fields: [createdById], references: [id], onDelete: Cascade)
  acceptedBy   User?                 @relation("PlaygroundInviteAcceptor", fields: [acceptedById], references: [id])
}

model PlaygroundChatMessage {
  id           String      @id @default(auto()) @map("_id") @db.ObjectId
  playgroundId String      @db.ObjectId
  authorId     String      @db.ObjectId
  content      String
  createdAt    DateTime    @default(now())
  playground   Playground  @relation(fields: [playgroundId], references: [id], onDelete: Cascade)
  author       User        @relation("PlaygroundChatAuthor", fields: [authorId], references: [id], onDelete: Cascade)
}

model PlaygroundActivity {
  id           String                 @id @default(auto()) @map("_id") @db.ObjectId
  playgroundId String                 @db.ObjectId
  actorId      String?                @db.ObjectId
  type         PlaygroundActivityType
  message      String
  filePath     String?
  metadata     Json?
  dedupeKey    String?
  createdAt    DateTime               @default(now())
  playground   Playground             @relation(fields: [playgroundId], references: [id], onDelete: Cascade)
  actor        User?                  @relation("PlaygroundActivityActor", fields: [actorId], references: [id])
}
