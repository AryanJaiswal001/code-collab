generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("MONGO_URI")
}

model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  ownedPlaygrounds Playground[] @relation("PlaygroundOwner")
}

model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.String
  access_token      String? @db.String
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.String
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum WorkspaceMode {
  PERSONAL
  COLLABORATION
}

enum PlaygroundSetupType {
  TEMPLATE
  GITHUB
}

enum WorkspaceRulesMode {
  STRICT
  LENIENT
}

enum PlaygroundTemplate {
  REACT
  NEXTJS
  EXPRESS
  VUE
  HONO
  ANGULAR
  GITHUB
}

model Playground {
  id                 String              @id @default(auto()) @map("_id") @db.ObjectId
  name               String
  description        String?
  mode               WorkspaceMode
  setupType          PlaygroundSetupType
  rules              WorkspaceRulesMode
  template           PlaygroundTemplate
  workspaceLink      String              @unique
  repositoryFullName String?
  collaborators      String[]
  ownerId            String              @db.ObjectId
  owner              User                @relation("PlaygroundOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
}